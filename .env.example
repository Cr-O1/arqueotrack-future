# ─── Entorno ──────────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=cambia-esto-por-una-clave-muy-secreta-en-produccion

# ─── Base de Datos ─────────────────────────────────────────────────────────────
# Desarrollo (SQLite):
DATABASE_URL=sqlite:///arqueotrack.db

# Producción (PostgreSQL):
# DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/arqueotrack
# DATABASE_URL=postgresql://usuario:contraseña@postgres:5432/arqueotrack  # Docker

# ─── PostgreSQL (Docker Compose) ──────────────────────────────────────────────
POSTGRES_DB=arqueotrack
POSTGRES_USER=arqueotrack_user
POSTGRES_PASSWORD=cambia-esta-contraseña

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# REDIS_URL=redis://redis:6379/0  # Docker

# ─── Archivos subidos ─────────────────────────────────────────────────────────
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216  # 16 MB

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_FORMAT=console  # console | json

# ─── Email (preparado para futuras versiones) ─────────────────────────────────
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=1
# MAIL_USERNAME=tu@email.com
# MAIL_PASSWORD=tu_contraseña

# ─── Celery (v4.0 - Tareas asíncronas) ───────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_BROKER_URL=redis://redis:6379/1  # Docker
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── Flower (monitor Celery) ──────────────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=cambia-esta-clave-flower

# ─── Almacenamiento (v4.0) ────────────────────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=uploads
STORAGE_LOCAL_URL=/uploads
# STORAGE_BACKEND=s3
# AWS_ACCESS_KEY_ID=tu_access_key
# AWS_SECRET_ACCESS_KEY=tu_secret_key
# AWS_REGION=eu-west-1
# S3_BUCKET=arqueotrack-media
